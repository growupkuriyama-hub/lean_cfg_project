import LeanCfgProject.MCFG.FI_v2_1_SampleGeneratedPrefixEnumerationFamilyExact

/-!
# FI v2.1 Lean experiment: Gold wrapper for prefix-enumeration families

This layer is the learner-like wrapper for sample-level prefix-enumeration
families.  A learner supplies, for each finite sample, the generated grammar
shell plus a prefix-node enumeration family for all words in that sample.  The
checked consequence is sample consistency for each output grammar.
-/

namespace FIv21

universe u v w

section SampleGeneratedPrefixEnumerationFamilyGold

variable {N : Type w} {α : Type u}
variable [DecidableEq α]
variable {M : Type v} [Monoid M] [Fintype M]

/-- Learner-like map from finite samples to family-exact generated grammar
packages. -/
structure SampleGeneratedPrefixEnumerationFamilyLearner
    (G : WorkingMCFG N α) (obs : α → M) where
  exactPackage :
    (K : Finset (Word α)) →
      SampleGeneratedPrefixEnumerationFamilyExact G obs K

namespace SampleGeneratedPrefixEnumerationFamilyLearner

/-- Rule skeleton after seeing finite sample `K`. -/
def ruleSkeleton
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedPrefixEnumerationFamilyLearner G obs)
    (K : Finset (Word α)) : SampleGeneratedRuleSkeleton G obs K :=
  (L.exactPackage K).ruleSkeleton

/-- Rule-list package after seeing finite sample `K`. -/
noncomputable def ruleLists
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedPrefixEnumerationFamilyLearner G obs)
    (K : Finset (Word α)) : SampleGeneratedRuleListPackage G obs K :=
  (L.exactPackage K).ruleLists

/-- Output grammar after finite sample `K`. -/
noncomputable def grammar
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedPrefixEnumerationFamilyLearner G obs)
    (K : Finset (Word α)) :
    WorkingMCFG (SampleGeneratedGrammarNonterminal
      (L.ruleLists K).ruleSkeleton.skeleton) α :=
  (L.exactPackage K).toWorkingMCFG

/-- Output grammar is semantically well-formed. -/
theorem grammar_semanticWorkingConditions
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedPrefixEnumerationFamilyLearner G obs)
    (K : Finset (Word α)) :
    (L.grammar K).SemanticWorkingConditions := by
  exact (L.exactPackage K).semanticWorkingConditions

/-- The family associated with finite sample `K`. -/
def family
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedPrefixEnumerationFamilyLearner G obs)
    (K : Finset (Word α)) :
    SampleGeneratedPrefixEnumerationFamily (M := M) (L.ruleSkeleton K) :=
  (L.exactPackage K).family

/-- Every word in the finite sample is generated by the learner's output grammar
for that sample. -/
theorem sample_subset_stringLanguage
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedPrefixEnumerationFamilyLearner G obs)
    (K : Finset (Word α)) :
    ∀ w : Word α, w ∈ K → w ∈ (L.grammar K).StringLanguage := by
  exact (L.exactPackage K).sample_subset_stringLanguage

/-- A single sample word is generated by the learner's output grammar. -/
theorem word_mem_stringLanguage_of_mem
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedPrefixEnumerationFamilyLearner G obs)
    (K : Finset (Word α)) {w : Word α} (hw : w ∈ K) :
    w ∈ (L.grammar K).StringLanguage := by
  exact L.sample_subset_stringLanguage K w hw

end SampleGeneratedPrefixEnumerationFamilyLearner

/-- Gold-style summary for sample-level prefix-enumeration families. -/
structure SampleGeneratedPrefixEnumerationFamilyGoldSummary
    (G : WorkingMCFG N α) (obs : α → M) where
  learner : SampleGeneratedPrefixEnumerationFamilyLearner G obs
  characteristicSample : Finset (Word α)

namespace SampleGeneratedPrefixEnumerationFamilyGoldSummary

/-- Output grammar after finite sample `K`. -/
noncomputable def grammar
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedPrefixEnumerationFamilyGoldSummary G obs)
    (K : Finset (Word α)) :
    WorkingMCFG (SampleGeneratedGrammarNonterminal
      (S.learner.ruleLists K).ruleSkeleton.skeleton) α :=
  S.learner.grammar K

/-- Output grammar is semantically well-formed. -/
theorem grammar_semanticWorkingConditions
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedPrefixEnumerationFamilyGoldSummary G obs)
    (K : Finset (Word α)) :
    (S.grammar K).SemanticWorkingConditions := by
  exact S.learner.grammar_semanticWorkingConditions K

/-- Every word in finite sample `K` is generated by the summary's output grammar
for `K`. -/
theorem sample_subset_stringLanguage
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedPrefixEnumerationFamilyGoldSummary G obs)
    (K : Finset (Word α)) :
    ∀ w : Word α, w ∈ K → w ∈ (S.grammar K).StringLanguage := by
  exact S.learner.sample_subset_stringLanguage K

/-- A single sample word is generated by the summary's output grammar. -/
theorem word_mem_stringLanguage_of_mem
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedPrefixEnumerationFamilyGoldSummary G obs)
    (K : Finset (Word α)) {w : Word α} (hw : w ∈ K) :
    w ∈ (S.grammar K).StringLanguage := by
  exact S.sample_subset_stringLanguage K w hw

end SampleGeneratedPrefixEnumerationFamilyGoldSummary

/-- Build a family learner from an exact-package provider. -/
def SampleGeneratedPrefixEnumerationFamilyLearner.ofExactPackages
    {G : WorkingMCFG N α} {obs : α → M}
    (E : (K : Finset (Word α)) →
      SampleGeneratedPrefixEnumerationFamilyExact G obs K) :
    SampleGeneratedPrefixEnumerationFamilyLearner G obs :=
  { exactPackage := E }

end SampleGeneratedPrefixEnumerationFamilyGold

end FIv21
