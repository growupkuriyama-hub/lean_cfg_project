import LeanCfgProject.MCFG.FI_v2_1_SampleGeneratedConsistencyToPackageExact

/-!
# FI v2.1 Lean experiment: Gold wrapper for generated consistency packages

This layer packages the sample-generated consistency bridge as a learner-like
map from finite samples to generated grammars.  The checked consequence remains
sample consistency: for every finite sample `K`, the generated grammar for `K`
contains all words of `K`.
-/

namespace FIv21

universe u v w

section SampleGeneratedConsistencyToPackageGold

variable {N : Type w} {α : Type u}
variable [DecidableEq α]
variable {M : Type v} [Monoid M] [Fintype M]

/-- Learner-like map from finite samples to generated consistency packages. -/
structure SampleGeneratedConsistencyPackageLearner
    (G : WorkingMCFG N α) (obs : α → M) where
  exactPackage :
    (K : Finset (Word α)) → SampleGeneratedConsistencyPackageExact G obs K

namespace SampleGeneratedConsistencyPackageLearner

/-- Package after finite sample `K`. -/
def package
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    SampleGeneratedConsistencyPackage G obs K :=
  (L.exactPackage K).package

/-- Rule skeleton after finite sample `K`. -/
def ruleSkeleton
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    SampleGeneratedRuleSkeleton G obs K :=
  (L.exactPackage K).ruleSkeleton

/-- Rule lists after finite sample `K`. -/
noncomputable def ruleLists
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    SampleGeneratedRuleListPackage G obs K :=
  (L.exactPackage K).ruleLists

/-- Output grammar after finite sample `K`. -/
noncomputable def grammar
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    WorkingMCFG (SampleGeneratedGrammarNonterminal
      (L.ruleLists K).ruleSkeleton.skeleton) α :=
  (L.exactPackage K).grammar

/-- Output language after finite sample `K`. -/
noncomputable def language
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) : Set (Word α) :=
  (L.grammar K).StringLanguage

/-- Output grammar is semantically well-formed. -/
theorem grammar_semanticWorkingConditions
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    (L.grammar K).SemanticWorkingConditions := by
  exact (L.exactPackage K).semanticWorkingConditions

/-- Each finite sample has no empty words according to the package branch. -/
def nonemptySample
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    NonemptyWordSample K :=
  (L.exactPackage K).nonemptySample

/-- Every word in finite sample `K` is generated by the learner's output grammar
for `K`. -/
theorem sample_subset_language
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    ∀ w : Word α, w ∈ K → w ∈ L.language K := by
  exact (L.exactPackage K).sample_subset_language

/-- The finite sample is positive for the learner's generated language. -/
theorem positiveForLanguage
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    PositiveForLanguage K (L.language K) := by
  exact L.sample_subset_language K

/-- Compact word-language certificate at sample `K`. -/
noncomputable def wordLanguageCertificate
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) :
    SampleGeneratedWordLanguageCertificate (α := α) K :=
  (L.exactPackage K).toWordLanguageCertificate

/-- Pointwise sample generation. -/
theorem word_mem_generatedLanguage
    {G : WorkingMCFG N α} {obs : α → M}
    (L : SampleGeneratedConsistencyPackageLearner G obs)
    (K : Finset (Word α)) {w : Word α} (hw : w ∈ K) :
    w ∈ L.language K := by
  exact L.sample_subset_language K w hw

end SampleGeneratedConsistencyPackageLearner

/-- Gold-style summary for the generated consistency-package branch. -/
structure SampleGeneratedConsistencyPackageGoldSummary
    (G : WorkingMCFG N α) (obs : α → M) where
  learner : SampleGeneratedConsistencyPackageLearner G obs
  characteristicSample : Finset (Word α)

namespace SampleGeneratedConsistencyPackageGoldSummary

/-- Output grammar after finite sample `K`. -/
noncomputable def grammar
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedConsistencyPackageGoldSummary G obs)
    (K : Finset (Word α)) :
    WorkingMCFG (SampleGeneratedGrammarNonterminal
      (S.learner.ruleLists K).ruleSkeleton.skeleton) α :=
  S.learner.grammar K

/-- Output language after finite sample `K`. -/
noncomputable def language
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedConsistencyPackageGoldSummary G obs)
    (K : Finset (Word α)) : Set (Word α) :=
  (S.grammar K).StringLanguage

/-- Output grammar is semantically well-formed. -/
theorem grammar_semanticWorkingConditions
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedConsistencyPackageGoldSummary G obs)
    (K : Finset (Word α)) :
    (S.grammar K).SemanticWorkingConditions := by
  exact S.learner.grammar_semanticWorkingConditions K

/-- Every word in finite sample `K` is generated by the summary's output grammar
for `K`. -/
theorem sample_subset_language
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedConsistencyPackageGoldSummary G obs)
    (K : Finset (Word α)) :
    ∀ w : Word α, w ∈ K → w ∈ S.language K := by
  exact S.learner.sample_subset_language K

/-- The finite sample is positive for the summary's generated language. -/
theorem positiveForLanguage
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedConsistencyPackageGoldSummary G obs)
    (K : Finset (Word α)) :
    PositiveForLanguage K (S.language K) := by
  exact S.sample_subset_language K

/-- Pointwise sample generation. -/
theorem word_mem_generatedLanguage
    {G : WorkingMCFG N α} {obs : α → M}
    (S : SampleGeneratedConsistencyPackageGoldSummary G obs)
    (K : Finset (Word α)) {w : Word α} (hw : w ∈ K) :
    w ∈ S.language K := by
  exact S.sample_subset_language K w hw

end SampleGeneratedConsistencyPackageGoldSummary

/-- Build a generated-consistency learner from exact packages. -/
def SampleGeneratedConsistencyPackageLearner.ofExactPackages
    {G : WorkingMCFG N α} {obs : α → M}
    (E : (K : Finset (Word α)) →
      SampleGeneratedConsistencyPackageExact G obs K) :
    SampleGeneratedConsistencyPackageLearner G obs :=
  { exactPackage := E }

end SampleGeneratedConsistencyToPackageGold

end FIv21
